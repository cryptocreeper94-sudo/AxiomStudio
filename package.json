{
  "name": "axiom-studio",
  "version": "2.0.0",
  "type": "module",
  "description": "Axiom Studio — Multi-Agent AI Coding IDE by DarkWave Studios. Local mode with full filesystem access.",
  "license": "UNLICENSED",
  "author": "DarkWave Studios LLC",
  "homepage": "https://axiomstudio.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/cryptocreeper94-sudo/Axiom-Studio.git"
  },
  "bin": {
    "axiom-studio": "./bin/axiom-studio.js"
  },
  "files": [
    "bin/",
    "dist/",
    "public/",
    "shared/",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx server/index.ts",
    "dev:client": "vite dev --port 5101",
    "local": "cross-env AXIOM_LOCAL=true tsx server/local-index.ts",
    "prepublishOnly": "npm run build",
    "build": "npx vite build && npx tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "check": "tsc --noEmit",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.60.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.23.24",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.545.0",
    "marked": "^15.0.0",
    "node-pty": "^1.1.0",
    "open": "^11.0.0",
    "openai": "^6.16.0",
    "pg": "^8.16.3",
    "postcss": "^8.5.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "stripe": "^22.1.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.20.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "wouter": "^3.3.5",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0"
  }
}
