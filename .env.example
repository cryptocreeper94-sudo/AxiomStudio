# Axiom Studio — Environment Variables
# Copy this to .env and fill in your values
# DO NOT commit .env to version control

# Required — server will not start without these
JWT_SECRET=
DATABASE_URL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Required for Google/GitHub OAuth
# Value: the full JSON string of your Firebase service account private key
FIREBASE_SERVICE_ACCOUNT=

# Server
APP_URL=http://localhost:5100
PORT=5100
NODE_ENV=development
TZ=America/Chicago

# Stripe (billing — can be empty for dev, purchase flow won't work)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_BUILDER=
STRIPE_PRICE_POWER=
STRIPE_PRICE_STUDIO=

# Optional
WORKSPACE_ROOT=./workspaces

# Twilio (SMS / Notifications — optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
